---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../lib/url';
---

<BaseLayout title="Stránka nenalezena – Hypotéka.cz" description="Hledaná stránka neexistuje." fullWidth>
	<div class="max-w-7xl mx-auto px-6 py-24 text-center">
		<div class="mb-8">
			<span class="material-symbols-outlined text-8xl text-outline-variant">explore_off</span>
		</div>

		<h1 class="text-5xl md:text-6xl font-black tracking-tighter text-on-background mb-4">404</h1>
		<p class="text-xl text-on-surface-variant mb-2">Tahle stránka neexistuje.</p>
		<p class="text-on-surface-variant mb-10">Možná se přestěhovala, nebo jsi špatně zadal/a adresu.</p>

		<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
			<a href={url('/')} class="bg-gradient-primary text-white text-lg px-8 py-4 rounded-lg font-bold hover:opacity-90 active:scale-95 transition-all no-underline">
				Zpět na hlavní stránku
			</a>
			<a href={url('/kalkulacky')} class="bg-surface-container-high text-on-surface-variant text-lg px-8 py-4 rounded-lg font-bold hover:bg-outline-variant/30 transition-all no-underline">
				Kalkulačky
			</a>
		</div>

		<!-- Quick links -->
		<div class="mt-16 max-w-2xl mx-auto">
			<p class="text-sm font-bold text-on-surface-variant uppercase tracking-wider mb-6">Mohlo by tě zajímat</p>
			<div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
				<a href={url('/kalkulacky/najem-vs-vlastni')} class="bg-surface-container-lowest p-5 rounded-xl ambient-shadow hover:-translate-y-0.5 transition-all no-underline text-left">
					<span class="material-symbols-outlined text-primary-deep text-2xl mb-2">compare_arrows</span>
					<p class="font-bold text-on-background text-sm">Nájem vs. vlastní</p>
				</a>
				<a href={url('/kalkulacky/splatka-hypoteky')} class="bg-surface-container-lowest p-5 rounded-xl ambient-shadow hover:-translate-y-0.5 transition-all no-underline text-left">
					<span class="material-symbols-outlined text-secondary-container text-2xl mb-2">payments</span>
					<p class="font-bold text-on-background text-sm">Splátka hypotéky</p>
				</a>
				<a href={url('/clanky')} class="bg-surface-container-lowest p-5 rounded-xl ambient-shadow hover:-translate-y-0.5 transition-all no-underline text-left">
					<span class="material-symbols-outlined text-tertiary text-2xl mb-2">menu_book</span>
					<p class="font-bold text-on-background text-sm">Články</p>
				</a>
			</div>
		</div>
	</div>
</BaseLayout>
