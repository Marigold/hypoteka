---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { url } from '../../lib/url';

const articles = (await getCollection('articles')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Články – Hypotéka na rovinu" description="Průvodci a články o hypotékách, fixacích, státní podpoře a bydlení v Česku." fullWidth>
	<div class="max-w-7xl mx-auto px-6 py-16">
		<div class="mb-16">
			<h1 class="text-4xl md:text-5xl font-black tracking-tighter mb-4">Články</h1>
			<p class="text-on-surface-variant text-lg max-w-2xl">Srozumitelné průvodce světem hypoték. Žádný bankovní žargon, slibujeme.</p>
		</div>

		{articles.length === 0 ? (
			<div class="bg-surface-container-low rounded-xl p-12 text-center">
				<span class="material-symbols-outlined text-5xl text-outline-variant mb-4">edit_note</span>
				<p class="text-on-surface-variant text-lg">Zatím žádné články. Pracujeme na tom!</p>
			</div>
		) : (
			<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
				{articles.map((entry) => (
					<a href={url(`/clanky/${entry.id}`)} class="group bg-surface-container-lowest p-8 rounded-xl ambient-shadow hover:-translate-y-1 transition-all no-underline">
						<div class="flex items-center gap-2 mb-6">
							<span class="text-xs font-bold uppercase tracking-wider text-primary-deep bg-primary-deep/10 px-3 py-1 rounded-full">
								{entry.data.category}
							</span>
							<span class="text-xs text-on-surface-variant">
								{entry.data.pubDate.toLocaleDateString('cs-CZ', { year: 'numeric', month: 'short', day: 'numeric' })}
							</span>
						</div>
						<h2 class="text-xl font-bold mb-3 tracking-tight text-on-background group-hover:text-primary-deep transition-colors">
							{entry.data.title}
						</h2>
						<p class="text-on-surface-variant text-sm leading-relaxed">{entry.data.description}</p>
						<div class="mt-6 flex items-center gap-1 text-sm font-medium text-primary-deep opacity-0 group-hover:opacity-100 transition-opacity">
							Číst dál
							<span class="material-symbols-outlined text-[18px]">arrow_forward</span>
						</div>
					</a>
				))}
			</div>
		)}
	</div>
</BaseLayout>
