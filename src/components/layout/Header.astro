---
const navLinks = [
	{ href: '/kalkulacky', label: 'Kalkulačky' },
	{ href: '/clanky', label: 'Články' },
	{ href: '/o-projektu', label: 'O projektu' },
];

const currentPath = Astro.url.pathname;
---

<nav class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-xl shadow-sm">
	<div class="flex justify-between items-center px-6 py-4 max-w-7xl mx-auto">
		<a href="/" class="text-2xl font-black tracking-tighter text-primary-deep no-underline">
			Hypotéka.cz
		</a>

		<!-- Desktop nav -->
		<div class="hidden md:flex items-center gap-8 font-medium tracking-tight">
			{navLinks.map(({ href, label }) => (
				<a
					href={href}
					class:list={[
						'transition-colors no-underline',
						currentPath === href
							? 'text-primary-deep font-semibold'
							: 'text-on-surface-variant hover:text-primary-deep',
					]}
				>
					{label}
				</a>
			))}
		</div>

		<div class="flex items-center gap-4">
			<!-- Mobile menu button -->
			<div class="dropdown dropdown-end md:hidden">
				<div tabindex="0" role="button" class="btn btn-ghost btn-sm" aria-label="Menu">
					<span class="material-symbols-outlined">menu</span>
				</div>
				<ul tabindex="0" class="menu menu-sm dropdown-content bg-white rounded-xl z-50 mt-3 w-56 p-3 shadow-lg border border-outline-variant/20 gap-1">
					{navLinks.map(({ href, label }) => (
						<li>
							<a
								href={href}
								class:list={[
									'rounded-lg py-3 px-4 text-base transition-colors',
									currentPath === href ? 'bg-primary-deep/10 text-primary-deep font-semibold' : 'hover:bg-surface-container',
								]}
							>
								{label}
							</a>
						</li>
					))}
				</ul>
			</div>

			<a href="/kalkulacky/splatka-hypoteky" class="bg-gradient-primary text-white px-6 py-2.5 rounded-lg font-bold hover:opacity-90 active:scale-95 transition-all no-underline hidden sm:inline-flex">
				Spočítat hypotéku
			</a>
		</div>
	</div>
</nav>
