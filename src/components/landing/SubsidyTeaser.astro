---
import { url } from '../../lib/url';

const programs = [
	{
		icon: 'gavel',
		title: 'Zákon o podpoře v bydlení',
		description: '115 kontaktních míst po celé ČR s bezplatným právním poradenstvím k bydlení.',
	},
	{
		icon: 'apartment',
		title: 'Družstevní bydlení',
		description: 'Úroky z úvěrů na družstevní bydlení nově odečitatelné z daní (max 150 000 Kč/rok).',
	},
	{
		icon: 'person',
		title: 'Výhody pro mladé do 36 let',
		description: 'Hypotéka až na 90 % hodnoty nemovitosti — oproti standardním 80 % LTV.',
	},
];
---

<section class="max-w-7xl mx-auto px-6 py-24">
	<div class="bg-gradient-primary rounded-2xl p-8 md:p-16 text-white relative overflow-hidden">
		<!-- Decorative blob -->
		<div class="absolute top-0 right-0 w-1/3 h-full opacity-10 pointer-events-none" aria-hidden="true">
			<svg class="h-full w-full" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
				<path d="M47.5,-59.2C61.4,-51.2,72.4,-37.1,76.5,-21.3C80.6,-5.5,77.7,11.9,70.1,27.1C62.5,42.4,50.1,55.4,35.4,63.1C20.7,70.8,3.6,73.1,-13.3,70C-30.2,66.9,-46.9,58.3,-58.5,45.1C-70.1,31.9,-76.6,14,-75,-2.9C-73.4,-19.8,-63.7,-35.6,-50.8,-43.8C-37.9,-52.1,-21.8,-52.8,-5.5,-55.5C10.8,-58.2,21.6,-62.8,33.5,-67.2C45.3,-71.6,58.2,-75.8,47.5,-59.2Z" fill="#FFFFFF" transform="translate(100 100)" />
			</svg>
		</div>

		<div class="relative z-10 flex flex-col lg:flex-row justify-between items-end gap-12">
			<div class="space-y-6 max-w-2xl">
				<span class="bg-white/20 px-4 py-1.5 rounded-full text-sm font-bold tracking-widest uppercase">
					Novinky 2026
				</span>
				<h2 class="text-4xl md:text-6xl font-black tracking-tighter">
					Státní podpora bydlení 2026
				</h2>
				<p class="text-white/80 text-lg leading-relaxed">
					Česko rozšiřuje programy na podporu dostupného bydlení. Pomůžeme ti se v&nbsp;nich zorientovat.
				</p>
			</div>
			<a href={url('/podpora')} class="bg-white text-primary-deep px-8 py-4 rounded-lg font-black hover:bg-white/90 transition-all whitespace-nowrap no-underline">
				Zjistit více
			</a>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-16 relative z-10">
			{programs.map((program) => (
				<div class="bg-white/10 backdrop-blur-md p-6 rounded-xl hover:bg-white/20 transition-all">
					<span class="material-symbols-outlined text-white text-4xl mb-4">{program.icon}</span>
					<h5 class="text-xl font-bold mb-2">{program.title}</h5>
					<p class="text-sm text-white/80">{program.description}</p>
				</div>
			))}
		</div>
	</div>
</section>
