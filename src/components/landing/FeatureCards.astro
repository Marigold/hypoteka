---
import { url } from '../../lib/url';

const cards = [
	{
		href: url('/kalkulacky/najem-vs-vlastni'),
		icon: 'compare_arrows',
		iconBg: 'bg-primary-deep/10',
		iconColor: 'text-primary-deep',
		hoverColor: 'group-hover:text-primary-deep',
		title: 'Nájem vs. vlastní',
		description: 'Vyplatí se ti dnes kupovat, nebo raději zůstat v nájmu a investovat? Porovnej oba scénáře na 20 let.',
	},
	{
		href: url('/kalkulacky/splatka-hypoteky'),
		icon: 'payments',
		iconBg: 'bg-secondary-container/10',
		iconColor: 'text-secondary-container',
		hoverColor: 'group-hover:text-secondary-container',
		title: 'Kolik budeš platit',
		description: 'Detailní rozpis měsíční splátky, úroku a jistiny. Podívej se, jak se mění splátka při změně sazby.',
	},
	{
		href: url('/kalkulacky/stresovy-test'),
		icon: 'warning',
		iconBg: 'bg-error-container/20',
		iconColor: 'text-error',
		hoverColor: 'group-hover:text-error',
		title: 'Stresový test',
		description: 'Uneseš zvýšení splátky o 5 000 Kč? Otestuj svoje finance na nejhorší možný scénář.',
	},
	{
		href: url('/clanky'),
		icon: 'menu_book',
		iconBg: 'bg-tertiary-fixed',
		iconColor: 'text-tertiary',
		hoverColor: 'group-hover:text-tertiary',
		title: 'Články a vzdělávání',
		description: 'Hypoteční průvodce pro začátečníky i pokročilé. Pochop fixaci, LTV i RPSN bez bankovního žargonu.',
	},
];
---

<section class="max-w-7xl mx-auto px-6 py-24">
	<div class="mb-16">
		<h2 class="text-4xl md:text-5xl font-black tracking-tighter mb-4">Vše pro tvoje rozhodnutí.</h2>
		<p class="text-on-surface-variant text-lg max-w-2xl">Nástroje, které ti pomohou pochopit realitu českého trhu s&nbsp;bydlením.</p>
	</div>

	<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
		{cards.map((card) => (
			<a
				href={card.href}
				class="group bg-surface-container-lowest p-8 rounded-xl ambient-shadow hover:-translate-y-1 transition-all no-underline"
			>
				<div class="flex justify-between items-start mb-12">
					<div class:list={['w-14 h-14 rounded-xl flex items-center justify-center', card.iconBg]}>
						<span class:list={['material-symbols-outlined text-3xl', card.iconColor]}>{card.icon}</span>
					</div>
					<span class:list={['material-symbols-outlined text-outline-variant transition-colors', card.hoverColor]}>arrow_forward_ios</span>
				</div>
				<h3 class="text-2xl font-bold mb-3 tracking-tight text-on-background">{card.title}</h3>
				<p class="text-on-surface-variant leading-relaxed">{card.description}</p>
			</a>
		))}
	</div>
</section>
