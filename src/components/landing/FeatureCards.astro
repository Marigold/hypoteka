---
const cards = [
	{
		href: '/kalkulacky/najem-vs-vlastni',
		iconBg: 'bg-primary/10',
		borderColor: 'border-t-primary',
		iconColor: 'text-primary',
		title: 'Nájem vs. vlastní',
		description: 'Vyplatí se ti víc nájem, nebo hypotéka? Spočítej si to.',
		svg: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0 0 12 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 0 1-2.031.352 5.988 5.988 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971Zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 0 1-2.031.352 5.989 5.989 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971Z" />',
	},
	{
		href: '/kalkulacky/splatka-hypoteky',
		iconBg: 'bg-secondary/10',
		borderColor: 'border-t-secondary',
		iconColor: 'text-secondary',
		title: 'Kolik budeš platit',
		description: 'Měsíční splátka, celkové náklady a kolik na tobě vydělá banka.',
		svg: '<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008Zm0 2.25h.008v.008H8.25V13.5Zm0 2.25h.008v.008H8.25v-.008Zm0 2.25h.008v.008H8.25V18Zm2.498-6.75h.007v.008h-.007v-.008Zm0 2.25h.007v.008h-.007V13.5Zm0 2.25h.007v.008h-.007v-.008Zm0 2.25h.007v.008h-.007V18Zm2.504-6.75h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V13.5Zm0 2.25h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V18Zm2.498-6.75h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V13.5ZM8.25 6h7.5v2.25h-7.5V6ZM12 2.25c-1.892 0-3.758.11-5.593.322C5.307 2.7 4.5 3.65 4.5 4.757V19.5a2.25 2.25 0 0 0 2.25 2.25h10.5a2.25 2.25 0 0 0 2.25-2.25V4.757c0-1.108-.806-2.057-1.907-2.185A48.507 48.507 0 0 0 12 2.25Z" />',
	},
	{
		href: '/kalkulacky/stresovy-test',
		iconBg: 'bg-accent/10',
		borderColor: 'border-t-accent',
		iconColor: 'text-accent',
		title: 'Stresový test',
		description: 'Co když úroky vyletí nahoru? Nebo přijdeš o část příjmu? Zjisti, jestli to dáš.',
		svg: '<path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 0 0 .495-7.468 5.99 5.99 0 0 0-1.925 3.547 5.975 5.975 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z" />',
	},
	{
		href: '/clanky',
		iconBg: 'bg-info/10',
		borderColor: 'border-t-info',
		iconColor: 'text-info',
		title: 'Články',
		description: 'Jak funguje hypotéka, co je fixace, jaké jsou dotace – bez bankovního balastu.',
		svg: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />',
	},
];
---

<section class="max-w-6xl mx-auto px-6">
	<div class="text-center mb-10">
		<h2 class="text-3xl font-bold">Co tu najdeš</h2>
		<p class="text-base-content/60 mt-2 max-w-lg mx-auto">Nástroje a informace, které ti pomohou udělat správné rozhodnutí.</p>
	</div>
	<div class="grid gap-6 sm:grid-cols-2">
		{cards.map((card) => (
			<a
				href={card.href}
				class:list={[
					'card bg-base-100 border border-base-200 border-t-4 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline overflow-hidden group',
					card.borderColor,
				]}
			>
				<div class="card-body">
					<div
						class:list={[
							'w-12 h-12 rounded-xl flex items-center justify-center mb-3 transition-transform duration-300 group-hover:scale-110',
							card.iconBg,
						]}
					>
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class:list={['w-6 h-6', card.iconColor]}>
							<Fragment set:html={card.svg} />
						</svg>
					</div>
					<h3 class="card-title text-lg">{card.title}</h3>
					<p class="text-base-content/60 text-sm leading-relaxed">{card.description}</p>
					<div class="mt-2 text-sm font-medium text-primary opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center gap-1">
						Zjistit více
						<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
							<path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
						</svg>
					</div>
				</div>
			</a>
		))}
	</div>
</section>
