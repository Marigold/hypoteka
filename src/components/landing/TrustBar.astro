---
const badges = [
	{ icon: 'account_balance', label: 'Data z ČNB' },
	{ icon: 'monitoring', label: 'Data z ČSÚ' },
	{ icon: 'update', label: 'Aktualizováno 2026' },
	{ icon: 'verified_user', label: 'Bez reklam a provizí' },
];
---

<section class="max-w-7xl mx-auto px-6 py-8 border-y border-outline-variant/10">
	<div class="flex flex-wrap justify-center md:justify-between items-center gap-8 md:gap-4 opacity-70 hover:opacity-100 transition-all">
		{badges.map(({ icon, label }) => (
			<div class="flex items-center gap-3">
				<span class="material-symbols-outlined text-on-surface-variant">{icon}</span>
				<span class="font-bold text-on-surface-variant text-sm">{label}</span>
			</div>
		))}
	</div>
</section>
