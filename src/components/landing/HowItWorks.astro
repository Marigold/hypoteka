---
const steps = [
	{
		number: 1,
		title: 'Vyber kalkulačku',
		description: 'Zvol si nástroj podle toho, co potřebuješ zjistit – splátku, srovnání nájmu, nebo stresový test.',
		svg: '<path stroke-linecap="round" stroke-linejoin="round" d="M15.042 21.672 13.684 16.6m0 0-2.51 2.225.569-9.47 5.227 7.917-3.286-.672ZM12 2.25V4.5m5.834.166-1.591 1.591M20.25 10.5H18M7.757 14.743l-1.59 1.59M6 10.5H3.75m4.007-4.243-1.59-1.59" />',
	},
	{
		number: 2,
		title: 'Zadej svou situaci',
		description: 'Vyplň pár čísel – příjem, cenu nemovitosti, úspory. Žádná registrace, žádné osobní údaje.',
		svg: '<path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />',
	},
	{
		number: 3,
		title: 'Získej odpověď',
		description: 'Okamžitě uvidíš výsledky s vysvětlením. Srozumitelně, bez bankovního žargonu.',
		svg: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />',
	},
];
---

<section class="max-w-6xl mx-auto px-6 py-16">
	<h2 class="text-3xl font-bold text-center mb-12">Jak to funguje</h2>
	<div class="grid gap-10 sm:grid-cols-3 relative">
		<!-- Connecting line (desktop only) -->
		<div class="hidden sm:block absolute top-10 left-[16.67%] right-[16.67%] h-0.5 bg-gradient-to-r from-primary/30 via-secondary/30 to-accent/30" aria-hidden="true"></div>

		{steps.map((step) => (
			<div class="relative flex flex-col items-center text-center">
				<div class="w-20 h-20 rounded-2xl bg-primary/10 flex items-center justify-center mb-5 relative z-10">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-primary">
						<Fragment set:html={step.svg} />
					</svg>
				</div>
				<span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-primary text-primary-content text-sm font-bold mb-3">
					{step.number}
				</span>
				<h3 class="font-semibold text-lg mb-2">{step.title}</h3>
				<p class="text-base-content/60 text-sm max-w-xs leading-relaxed">{step.description}</p>
			</div>
		))}
	</div>
</section>
