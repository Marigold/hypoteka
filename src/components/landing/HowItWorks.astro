---
const steps = [
	{
		number: 1,
		title: 'Zadej svoji situaci',
		description: 'Stačí přibližná cena nemovitosti a tvoje úspory. Žádná registrace, žádné osobní údaje.',
	},
	{
		number: 2,
		title: 'Vyber kalkulačku',
		description: 'Srovnání nájmu vs. vlastního, stresový test, optimalizace fixace – vyber si, co potřebuješ.',
	},
	{
		number: 3,
		title: 'Získej odpovědi',
		description: 'Okamžitě uvidíš výsledky s vysvětlením. Srozumitelně, bez zbytečného balastu.',
	},
];
---

<section id="jak-to-funguje" class="bg-surface-container-low py-24">
	<div class="max-w-7xl mx-auto px-6">
		<div class="text-center mb-20">
			<h2 class="text-4xl md:text-5xl font-black tracking-tighter">Jak to funguje</h2>
		</div>

		<div class="relative">
			<!-- Connecting line (desktop) -->
			<div class="hidden md:block absolute top-10 left-0 w-full h-0.5 bg-outline-variant/30 z-0" aria-hidden="true"></div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-12 relative z-10">
				{steps.map((step) => (
					<div class="text-center space-y-6">
						<div class="w-20 h-20 bg-gradient-primary text-white rounded-full flex items-center justify-center text-3xl font-black mx-auto border-8 border-surface-container-low">
							{step.number}
						</div>
						<div class="space-y-2">
							<h4 class="text-xl font-bold">{step.title}</h4>
							<p class="text-on-surface-variant px-4">{step.description}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</div>
</section>
