---
import BaseLayout from './BaseLayout.astro';
import { url } from '../lib/url';

interface Props {
	title: string;
	description: string;
	icon: string;
	iconBg: string;
	iconColor: string;
}

const { title, description, icon, iconBg, iconColor } = Astro.props;

const breadcrumbs = [
	{ label: 'Domů', href: url('/') },
	{ label: 'Kalkulačky', href: url('/kalkulacky') },
	{ label: title, href: null },
];
---

<BaseLayout title={`${title} – Hypotéka na rovinu`} description={description}>
	<!-- Breadcrumbs -->
	<nav aria-label="breadcrumbs" class="text-sm text-on-surface-variant mb-8">
		<ol class="flex flex-wrap items-center gap-1">
			{breadcrumbs.map((crumb, i) => (
				<li class="flex items-center gap-1">
					{i > 0 && <span aria-hidden="true" class="text-outline-variant">/</span>}
					{crumb.href ? (
						<a href={crumb.href} class="hover:text-primary-deep transition-colors no-underline">{crumb.label}</a>
					) : (
						<span class="text-on-background font-medium">{crumb.label}</span>
					)}
				</li>
			))}
		</ol>
	</nav>

	<!-- Header -->
	<div class="mb-8">
		<div>
			<h1 class="text-3xl font-black tracking-tight text-on-background mb-2">{title}</h1>
			<p class="text-on-surface-variant leading-relaxed">{description}</p>
		</div>
	</div>

	<!-- Calculator slot -->
	<div class="bg-surface-container-lowest rounded-xl ambient-shadow p-6 md:p-8">
		<slot />
	</div>

</BaseLayout>
