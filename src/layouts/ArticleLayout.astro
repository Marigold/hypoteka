---
import BaseLayout from './BaseLayout.astro';

interface Props {
	title: string;
	description: string;
	author: string;
	pubDate: Date;
	lastUpdated?: Date;
	category: string;
	disclaimer?: boolean;
}

const { title, description, author, pubDate, lastUpdated, category, disclaimer = true } = Astro.props;

const formatDate = (date: Date) =>
	date.toLocaleDateString('cs-CZ', { year: 'numeric', month: 'long', day: 'numeric' });

const breadcrumbs = [
	{ label: 'Domů', href: '/' },
	{ label: 'Články', href: '/clanky' },
	{ label: title, href: null },
];
---

<BaseLayout title={`${title} – Hypotéka.cz`} description={description}>
	<nav aria-label="breadcrumbs" class="text-sm text-gray-500 mb-6">
		<ol class="flex flex-wrap items-center gap-1">
			{breadcrumbs.map((crumb, i) => (
				<li class="flex items-center gap-1">
					{i > 0 && <span aria-hidden="true">/</span>}
					{crumb.href ? (
						<a href={crumb.href} class="hover:text-blue-600 underline">{crumb.label}</a>
					) : (
						<span class="text-gray-900 font-medium">{crumb.label}</span>
					)}
				</li>
			))}
		</ol>
	</nav>

	<article>
		<header class="mb-8">
			<p class="text-sm font-medium text-blue-600 mb-2">{category}</p>
			<h1 class="text-3xl font-bold mb-3">{title}</h1>
			<p class="text-gray-600 mb-4">{description}</p>
			<div class="flex flex-wrap items-center gap-4 text-sm text-gray-500">
				<span>{author}</span>
				<time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
				{lastUpdated && (
					<span>
						Aktualizováno: <time datetime={lastUpdated.toISOString()}>{formatDate(lastUpdated)}</time>
					</span>
				)}
			</div>
		</header>

		<div class="prose prose-gray max-w-none">
			<slot />
		</div>

		{disclaimer && (
			<div role="alert" class="mt-10 p-4 bg-amber-50 border border-amber-200 rounded-lg text-sm text-amber-800">
				<p class="font-semibold mb-1">Právní upozornění</p>
				<p>
					Tento článek slouží pouze k vzdělávacím účelům a nepředstavuje finanční poradenství.
					Před důležitým finančním rozhodnutím se vždy poraďte s licencovaným odborníkem.
					Data jsou platná k datu publikace a mohou se změnit.
				</p>
			</div>
		)}
	</article>
</BaseLayout>
